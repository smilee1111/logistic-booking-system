NODE_ENV=development

LOCAL_DATABASE_URI=mongodb://127.0.0.1:27017/bookio
PORT=5050

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
MFA_PENDING_SECRET=

BCRYPT_SALT_ROUNDS=12

# AES-256 key for encrypting mfaSecret at rest. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MFA_ENCRYPTION_KEY=

# Separate AES-256 key for encrypting Booking.contactPhone at rest — deliberately
# not the same key as MFA_ENCRYPTION_KEY.
CONTACT_ENCRYPTION_KEY=

COOKIE_SECURE=false

# From https://www.google.com/recaptcha/admin — server-side secret key only
RECAPTCHA_SECRET_KEY=

# Only this origin is allowed to make credentialed cross-origin requests
FRONTEND_ORIGIN=http://localhost:3000

# From https://console.cloud.google.com/apis/credentials — OAuth 2.0 Client ID
# (type: Web application). Authorized redirect URI must exactly match
# GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Gmail SMTP: requires 2-Step Verification enabled on the account, then create
# an App Password at https://myaccount.google.com/apppasswords — use that
# 16-character value, not your regular Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM="Lab & Equipment Booking <your-gmail@gmail.com>"
