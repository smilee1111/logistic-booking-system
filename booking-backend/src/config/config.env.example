NODE_ENV=development

LOCAL_DATABASE_URI=mongodb://127.0.0.1:27017/bookio
PORT=5050

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
MFA_PENDING_SECRET=

BCRYPT_SALT_ROUNDS=12

# AES-256 key for encrypting mfaSecret at rest. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MFA_ENCRYPTION_KEY=

COOKIE_SECURE=false

# From https://www.google.com/recaptcha/admin — server-side secret key only
RECAPTCHA_SECRET_KEY=
